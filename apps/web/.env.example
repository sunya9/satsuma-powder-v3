# Payload CMS base URL — build-time data source (SSG fetches here)
VITE_PAYLOAD_URL=http://localhost:3000
# Public R2 base URL — images are served directly from R2
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Public site URL — canonical / OGP (defaults to localhost in dev)
VITE_SITE_URL=https://example.com
# Payload API key for the build user. NOT VITE_-prefixed: build-time secret,
# never bundled to the client. Must match the cms build user's apiKey.
PAYLOAD_API_KEY=
