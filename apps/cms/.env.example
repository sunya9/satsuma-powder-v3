# ローカルは file:、本番(Turso)は libsql://<db>.turso.io
DATABASE_URL=file:./satsuma-powder-admin.db
# Turso(libsql) のリモートDBに接続する場合のみ必要
DATABASE_AUTH_TOKEN=
PAYLOAD_SECRET=YOUR_SECRET_HERE

# 画像ストレージ (S3 / Cloudflare R2)。media コレクションのアップロード先。
# 未設定ならローカルディスク(media/)へフォールバックする。
S3_BUCKET=
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ローカルテスト用 admin seed (pnpm seed:admin) の上書き。未設定なら admin@example.com / password。
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Cloudflare Workers Builds の Deploy Hook URL。コンテンツ更新時に POST して SSG を再ビルドする。
# 未設定なら再ビルド通知をスキップ(警告ログのみ)。URL 自体が認証情報なのでシークレット扱い。
CLOUDFLARE_DEPLOY_HOOK_URL=
