{
  "name": "satsuma",
  "private": true,
  "description": "satsuma monorepo — Payload CMS (apps/cms) と HonoX フロント (apps/web 予定)",
  "scripts": {
    "dev": "pnpm --filter satsuma-powder-admin dev",
    "build": "pnpm --filter satsuma-powder-admin build",
    "start": "pnpm --filter satsuma-powder-admin start",
    "cms": "pnpm --filter satsuma-powder-admin",
    "test": "pnpm --filter satsuma-powder-admin test:int",
    "migrate:ghost": "pnpm --filter satsuma-powder-admin migrate:ghost",
    "seed:admin": "pnpm --filter satsuma-powder-admin seed:admin"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
