{
  "name": "satsuma-powder-v3",
  "private": true,
  "description": "satsuma-powder-v3 monorepo — Payload CMS (apps/cms) and HonoX frontend (apps/web, planned)",
  "scripts": {
    "dev": "pnpm --filter cms dev",
    "build": "pnpm --filter cms build",
    "start": "pnpm --filter cms start",
    "cms": "pnpm --filter cms",
    "test": "pnpm --filter cms test:int",
    "migrate:ghost": "pnpm --filter cms migrate:ghost",
    "seed:admin": "pnpm --filter cms seed:admin"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
